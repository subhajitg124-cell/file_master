NODE_ENV=development
PORT=4173
BASE_PATH=/

DATABASE_URL=postgres://filemaster:filemaster@localhost:5432/filemaster_ai
REDIS_URL=redis://localhost:6379

S3_REGION=ap-south-1
S3_BUCKET=filemaster-ai-uploads
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_ENDPOINT=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=replace-with-strong-random-secret
CSRF_SECRET=replace-with-strong-random-secret

MAX_UPLOAD_MB=100
UPLOAD_TTL_MINUTES=60
ENABLE_VIRUS_SCAN=false
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_BACKGROUND_REMOVAL=true
