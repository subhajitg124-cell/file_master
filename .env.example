# Backend Gateway Config
DEBUG=True
REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_FILE_SIZE_MB=100
GLOBAL_RATE_LIMIT=60/minute

# Frontend Config
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
PORT=3000
